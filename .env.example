# Postgres
DATABASE_URL=postgres://meadow:meadowdev@localhost:5432/meadow

# Redis
REDIS_URL=redis://localhost:6379

# Auth — REQUIRED
# Generate with: openssl rand -hex 32
JWT_SECRET=replace_with_64_hex_chars_minimum_32_required
API_KEY_HMAC_SECRET=replace_with_64_hex_chars_minimum_32_required

# Cloudflare Domain Intel
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# OpenAI Moderations
OPENAI_API_KEY=

# API server
PORT=3000

# Comma-separated list of allowed CORS origins for the parent dashboard.
# Defaults to localhost dev ports if unset.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001
