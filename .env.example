# Postgres
DATABASE_URL=postgres://meadow:meadowdev@localhost:5432/meadow

# Redis
REDIS_URL=redis://localhost:6379

# Auth — REQUIRED
# Generate with: openssl rand -hex 32
JWT_SECRET=replace_with_64_hex_chars_minimum_32_required
API_KEY_HMAC_SECRET=replace_with_64_hex_chars_minimum_32_required

# Cloudflare Domain Intel
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# OpenAI Moderations
OPENAI_API_KEY=

# API server
PORT=3000

# Comma-separated list of allowed CORS origins for the parent dashboard.
# Defaults to localhost dev ports if unset.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001

# DNS server.
# Production (on the Pi via systemd CAP_NET_BIND_SERVICE): DNS_PORT=53
# Local dev (no privileges):                                DNS_PORT=5353
# Disable UDP DNS server entirely (e.g. tests):             DNS_PORT=0
DNS_PORT=5353

# Upstream DNS resolvers Meadow forwards allowed queries to. Comma-separated,
# tried in order. Default is Cloudflare.
UPSTREAM_DNS=1.1.1.1,1.0.0.1
