# Production env vars for the Meadow API (Fly.io).
#
# DO NOT commit a real .env.production. Set these via:
#   fly secrets set KEY=value [KEY=value ...]
#
# This file is the documentation of what needs to exist for the API to
# run in production. Local dev uses .env (see .env.example).

# ---------- Required ----------

# Managed Postgres on Fly. Generated when you run `fly postgres create`.
DATABASE_URL=postgres://USER:PASS@HOST:5432/meadow_prod

# Managed Redis on Fly (Upstash) or self-hosted. TLS strongly preferred.
REDIS_URL=rediss://default:PASS@HOST:6379

# Auth — generate fresh, never reuse dev values.
#   openssl rand -hex 32
JWT_SECRET=64_HEX_CHARS
API_KEY_HMAC_SECRET=64_HEX_CHARS

# CORS allowlist for the dashboard. The Express CORS middleware ALSO
# allows *.base44.com / *.base44.app by default (see src/api/server.ts).
ALLOWED_ORIGINS=https://meadow.dqsec.com,https://app.meadow.dqsec.com

# ---------- Optional ----------

# Box version label echoed in heartbeats (release tag is fine).
BOX_VERSION=1.0.0

# OpenAI for /api/v1/analyze content categorization. Leave unset to
# disable AI categorization — the resolver still works without it.
OPENAI_API_KEY=

# Cloudflare for future per-domain enrichment.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Email provider (Resend). If unset, verification + password-reset
# emails log to stdout instead of being delivered. Wire this before
# any non-household deployment.
#   1. Sign up at resend.com, add the dqsec.com domain.
#   2. Verify domain via DNS records Resend gives you.
#   3. Generate an API key, set it here.
RESEND_API_KEY=
# Optional override for the From address. Defaults to "Meadow <hello@dqsec.com>".
MEADOW_FROM_EMAIL=
# Where the dashboard lives — used to build verify/reset links.
DASHBOARD_URL=https://meadow.dqsec.com

# ---------- Signup gate ----------
# Open vs closed signup. Default is open ("true"). Set to "false" or
# "0" to close public signup; the dashboard signup form will start
# getting 403 {"error":"signup_closed"}.
#   - Strict matching: only "false" and "0" disable. "False"/"no"/etc.
#     keep signup open (operator-typo guard).
#   - Read at request time, so flipping via `fly secrets set` takes
#     effect on the next request (no full restart needed).
SIGNUP_ENABLED=true
# Optional invite code for closed-signup mode. When SIGNUP_ENABLED=false
# AND this is set, requests carrying a matching `invite_code` body
# field are admitted; everything else gets 403 signup_closed. When
# SIGNUP_ENABLED=true, this value is ignored entirely.
# Generate with: openssl rand -hex 16   (or pick something memorable
# for friends-and-family alpha)
SIGNUP_INVITE_CODE=

# ---------- DNS server ----------
# DNS_PORT=0 in production: the Fly-hosted API never serves UDP DNS;
# only the home box does. Hardcoded in fly.toml as well.
DNS_PORT=0
